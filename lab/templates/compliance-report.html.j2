<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Compliance Report - {{ report_data.organization }}</title>
    <style>
        body { font-family: 'Red Hat Display', 'Segoe UI', sans-serif; margin: 2rem; color: #1a1a1a; }
        h1 { color: #ee0000; border-bottom: 2px solid #ee0000; padding-bottom: 0.5rem; }
        h2 { color: #4a4a4a; margin-top: 2rem; }
        .meta { background: #f5f5f5; padding: 1rem; border-radius: 4px; margin: 1rem 0; }
        .meta dt { font-weight: bold; display: inline; }
        .meta dd { display: inline; margin-left: 0.5rem; margin-right: 2rem; }
        .pass { color: #2e7d32; font-weight: bold; }
        .fail { color: #c62828; font-weight: bold; }
        pre { background: #263238; color: #eeffff; padding: 1rem; border-radius: 4px; overflow-x: auto; }
        table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
        th, td { border: 1px solid #ddd; padding: 0.5rem; text-align: left; }
        th { background: #4a4a4a; color: white; }
        .footer { margin-top: 3rem; font-size: 0.9rem; color: #666; border-top: 1px solid #ddd; padding-top: 1rem; }
    </style>
</head>
<body>
    <h1>Vulnerability Remediation Compliance Report</h1>

    <div class="meta">
        <dl>
            <dt>Organization:</dt><dd>{{ report_data.organization }}</dd>
            <dt>Host:</dt><dd>{{ report_data.host }}</dd>
            <dt>Generated:</dt><dd>{{ report_data.timestamp }}</dd>
        </dl>
    </div>

    <h2>Vulnerability Summary</h2>
    <table>
        <tr><th>Field</th><th>Value</th></tr>
        <tr><td>CVE Identifier</td><td>{{ report_data.cve }}</td></tr>
        <tr><td>Advisory Applied</td><td>{{ report_data.advisory }}</td></tr>
        <tr><td>Current Package</td><td>{{ report_data.httpd_version }}</td></tr>
        <tr><td>Status</td><td><span class="pass">REMEDIATED</span></td></tr>
    </table>

    <h2>SELinux Status</h2>
    <pre>{{ report_data.selinux_status }}</pre>

    <h2>Firewall Configuration</h2>
    <pre>{{ report_data.firewall_config }}</pre>

    <h2>Listening Services</h2>
    <pre>{{ report_data.listening_ports }}</pre>

    <h2>Recent Package History</h2>
    <pre>{{ report_data.yum_history }}</pre>

    <div class="footer">
        <p>This report was automatically generated by the AAP Vulnerability Management Workflow.</p>
        <p>Compliance frameworks: PCI-DSS 6.2, NIST SP 800-53 SI-2</p>
    </div>
</body>
</html>
